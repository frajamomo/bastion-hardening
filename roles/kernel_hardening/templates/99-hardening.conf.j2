# Kernel Hardening - Managed by Ansible
# Do not edit manually

{% for key, value in sysctl_hardening.items() %}
{{ key }} = {{ value }}
{% endfor %}

{% if sysctl_extra is defined %}
# Host/group-specific extra sysctl settings
{% for key, value in sysctl_extra.items() %}
{{ key }} = {{ value }}
{% endfor %}
{% endif %}

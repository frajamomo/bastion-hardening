# Audit Hardening Rules - Managed by Ansible
# Do not edit manually

# Set buffer and failure mode
-b 8192
-f 1

# Monitor time changes
{% if ansible_architecture == 'x86_64' %}
-a always,exit -F arch=b64 -S adjtimex -S settimeofday -k time-change
-a always,exit -F arch=b64 -S clock_settime -k time-change
{% else %}
-a always,exit -F arch=b64 -S adjtimex -S settimeofday -S clock_settime -k time-change
{% endif %}
-w /etc/localtime -p wa -k time-change

# Monitor user/group changes
-w /etc/group -p wa -k identity
-w /etc/passwd -p wa -k identity
-w /etc/gshadow -p wa -k identity
-w /etc/shadow -p wa -k identity
-w /etc/security/opasswd -p wa -k identity

# Monitor network configuration
-w /etc/hosts -p wa -k system-locale
-w /etc/hostname -p wa -k system-locale

# Monitor login/logout events
-w /var/run/faillock/ -p wa -k logins
-w /var/log/lastlog -p wa -k logins
-w /var/log/wtmp -p wa -k logins
-w /var/log/btmp -p wa -k logins

# Monitor privilege escalation
-w /etc/sudoers -p wa -k actions
-w /etc/sudoers.d/ -p wa -k actions

# Monitor kernel module loading
-a always,exit -F arch=b64 -S init_module -S finit_module -S delete_module -k modules

# Monitor SSH configuration
-w /etc/ssh/sshd_config -p wa -k sshd_config
-w /etc/ssh/sshd_config.d/ -p wa -k sshd_config

{% if ansible_os_family == 'RedHat' %}
# Monitor SELinux changes
-w /etc/selinux/ -p wa -k MAC-policy
{% endif %}

# Monitor software installations
{% if ansible_os_family == 'RedHat' %}
-w /usr/bin/dnf -p x -k software_mgmt
-w /usr/bin/rpm -p x -k software_mgmt
{% else %}
-w /usr/bin/apt -p x -k software_mgmt
-w /usr/bin/dpkg -p x -k software_mgmt
{% endif %}

# Monitor file deletion by users
{% if ansible_architecture == 'x86_64' %}
-a always,exit -F arch=b64 -S unlink -S unlinkat -S rename -S renameat -F auid>=1000 -F auid!=4294967295 -k delete
{% else %}
-a always,exit -F arch=b64 -S unlinkat -S renameat -F auid>=1000 -F auid!=4294967295 -k delete
{% endif %}

# Monitor changes to audit configuration
-w /etc/audit/ -p wa -k auditconfig
-w /etc/audit/auditd.conf -p wa -k auditconfig
-w /etc/audit/rules.d/ -p wa -k auditconfig

{% if ansible_os_family == 'Debian' %}
# Monitor Docker configuration
-w /etc/docker/ -p wa -k docker_config
-w /usr/bin/docker -p x -k docker_cmd
{% endif %}

# Make the configuration immutable (must be last rule)
-e 2

---
# Copy this file to vault.yml and fill in your values, then encrypt:
#   cp vault.yml.example vault.yml
#   vi vault.yml
#   ansible-vault encrypt vault.yml

# Connection (Ansible magic variables)
ansible_user: "your_username"
ansible_ssh_private_key_file: "~/.ssh/id_ed25519"

# Target hosts
vault_e14_host: "192.168.x.x"
vault_rpi_host: "192.168.x.x"

# User
vault_user: "your_username"

# Network
vault_trusted_subnet: "192.168.x.0/24"

# OpenVPN
vault_openvpn_subnet: "10.x.x.0/24"

# NAS mount paths (AIDE exclusions)
vault_nas_mounts:
  - /mnt/nas_share1
  - /mnt/nas_share2
